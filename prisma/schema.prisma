generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  password              String?
  googleId              String?        @unique
  name                  String?
  role                  Role           @default(PLAYER)
  telegramChatId        String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  bookings              Booking[]
  clubs                 Club[]         @relation("ClubOwner")
  notifications         Notification[]
  favorites             Favorite[]
  reviews               Review[]
  adminProfile          Admin?

  // Notification Preferences
  emailNotifications    Boolean        @default(true)
  telegramNotifications Boolean        @default(true)
  pushNotifications     Boolean        @default(true)
  soundAlerts           Boolean        @default(true)

  // Privacy Settings
  shareHistory          Boolean        @default(true)
  profilePublic         Boolean        @default(true)
}

model Location {
  id        String   @id @default(uuid())
  city      String
  area      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clubs     Club[]

  @@index([city, area])
}

model Club {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  rating             Float          @default(0)
  coverImage         String?
  interiorImages     String[]
  amenities          String[]
  fullAddress        String?
  cancellationPolicy String?
  reschedulingPolicy String?
  lat                Float?
  lng                Float?
  openingTime        String
  closingTime        String
  ownerId            String
  locationId         String
  status             ClubStatus     @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  bookings           Booking[]
  location           Location       @relation(fields: [locationId], references: [id])
  owner              User           @relation("ClubOwner", fields: [ownerId], references: [id])
  products           Product[]
  tables             Table[]
  availabilities     Availability[]
  favorites          Favorite[]
  reviews            Review[]

  @@index([name])
}

model Table {
  id           String      @id @default(uuid())
  name         String
  type         TableType   @default(SNOOKER)
  pricePerHour Float
  status       TableStatus @default(AVAILABLE)
  clubId       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  club         Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  bookings     Booking[]

  @@index([clubId])
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  clubId     String
  tableId    String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(PENDING)
  totalPrice Float
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  club       Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  table      Table         @relation(fields: [tableId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tableId, startTime, endTime, status])
  @@index([userId])
  @@index([clubId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  clubId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  clubId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

model Availability {
  id        String   @id @default(uuid())
  clubId    String
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, dayOfWeek])
}

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

enum Role {
  PLAYER
  CLUB_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum ClubStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TableType {
  SNOOKER
  EIGHT_BALL_POOL
}

enum TableStatus {
  AVAILABLE
  MAINTENANCE
  UNAVAILABLE
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_APPROVED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  SYSTEM
}
