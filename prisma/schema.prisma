generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String?
  googleId       String?   @unique
  name           String?
  role           Role      @default(PLAYER)
  telegramChatId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]
  clubs          Club[]    @relation("ClubOwner")
}

model Location {
  id        String   @id @default(uuid())
  city      String
  area      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clubs     Club[]
}

model Club {
  id                 String          @id @default(uuid())
  name               String
  description        String?
  rating             Float           @default(0)
  coverImage         String?
  interiorImages     String[]
  amenities          String[]
  fullAddress        String?
  cancellationPolicy String?
  reschedulingPolicy String?
  lat                Float?
  lng                Float?
  openingTime        String
  closingTime        String
  ownerId            String
  locationId         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  bookings           Booking[]
  location           Location        @relation(fields: [locationId], references: [id])
  owner              User            @relation("ClubOwner", fields: [ownerId], references: [id])
  products           Product[]
  tableCategories    TableCategory[]
}

model TableCategory {
  id           String    @id @default(uuid())
  name         String
  quantity     Int
  pricePerHour Float
  image        String?
  clubId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
  club         Club      @relation(fields: [clubId], references: [id])
}

model Booking {
  id              String        @id @default(uuid())
  userId          String
  clubId          String
  tableCategoryId String
  startTime       DateTime
  endTime         DateTime
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  club            Club          @relation(fields: [clubId], references: [id])
  tableCategory   TableCategory @relation(fields: [tableCategoryId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id])
}

enum Role {
  PLAYER
  CLUB_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}
